# Copy this file to .env and fill in real values before running docker compose up.
# NEVER commit .env to version control.

# Guacamole PostgreSQL password (generate: openssl rand -base64 24)
POSTGRES_PASSWORD=

# Gitea Act Runner registration token (obtain from Gitea Admin > Actions > Runners)
GITEA_RUNNER_TOKEN=

# FastAPI service API key (generate: openssl rand -hex 32)
LAB_API_KEY=

# Redis password (generate: openssl rand -hex 24)
REDIS_PASSWORD=

# Gitea webhook HMAC secret (generate: openssl rand -hex 32)
# IMPORTANT: must be DIFFERENT from LAB_API_KEY (never reuse one secret for two controls).
GITEA_WEBHOOK_SECRET=

# Grafana admin password (generate: openssl rand -base64 18). Do NOT leave as 'admin'.
GRAFANA_PASSWORD=
