<?xml version="1.0" encoding="UTF-8"?>
<!--
  Cyclic motion (Gazebo) SROS2 permissions.
  Publishes /joint_states, subscribes to /safety/state, but MUST NOT publish /safety/request.
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://www.omg.org/spec/DDS-SECURITY/20170901/omg_shared_ca_permissions.xsd">
  <permissions>
    <grant name="/lab/cyclic_motion">
      <subject_name>CN=/lab/cyclic_motion</subject_name>
      <validity>
        <not_before>2024-01-01T00:00:00</not_before>
        <not_after>2034-01-01T00:00:00</not_after>
      </validity>

      <deny_rule>
        <domains><id>0</id></domains>
        <publish>
          <topics>
            <topic>rt/safety/*</topic>
          </topics>
        </publish>
      </deny_rule>

      <allow_rule>
        <domains><id>0</id></domains>
        <publish>
          <topics>
            <topic>rt/robot/joint_states</topic>
            <topic>rt/robot/cmd_vel</topic>
          </topics>
        </publish>
        <subscribe>
          <topics>
            <topic>rt/robot/*</topic>
            <topic>rt/diagnostics/*</topic>
            <topic>rt/safety/state</topic>
          </topics>
        </subscribe>
      </allow_rule>

      <default>DENY</default>
    </grant>
  </permissions>
</dds>
