<?xml version="1.0" encoding="UTF-8"?>
<!--
  Safety Supervisor SROS2 permissions.
  Owner of safety state: publishes /safety/state, subscribes /safety/request.
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://www.omg.org/spec/DDS-SECURITY/20170901/omg_shared_ca_permissions.xsd">
  <permissions>
    <grant name="/lab/safety_supervisor">
      <subject_name>CN=/lab/safety_supervisor</subject_name>
      <validity>
        <not_before>2024-01-01T00:00:00</not_before>
        <not_after>2034-01-01T00:00:00</not_after>
      </validity>

      <allow_rule>
        <domains><id>0</id></domains>
        <publish>
          <topics>
            <topic>rt/safety/state</topic>
          </topics>
        </publish>
        <subscribe>
          <topics>
            <topic>rt/safety/request</topic>
          </topics>
        </subscribe>
      </allow_rule>

      <default>DENY</default>
    </grant>
  </permissions>
</dds>
