<?xml version="1.0" encoding="UTF-8"?>
<!--
  AI subscriber SROS2 permissions.
  Read-only: vm-ai may subscribe to /safety/state for telemetry, but
  MUST NOT publish to /safety/request.
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://www.omg.org/spec/DDS-SECURITY/20170901/omg_shared_ca_permissions.xsd">
  <permissions>
    <grant name="/lab/ai_subscriber">
      <subject_name>CN=/lab/ai_subscriber</subject_name>
      <validity>
        <not_before>2024-01-01T00:00:00</not_before>
        <not_after>2034-01-01T00:00:00</not_after>
      </validity>

      <deny_rule>
        <domains><id>0</id></domains>
        <publish>
          <topics>
            <topic>rt/safety/request</topic>
            <topic>rt/safety/state</topic>
          </topics>
        </publish>
      </deny_rule>

      <allow_rule>
        <domains><id>0</id></domains>
        <publish>
          <topics>
            <topic>rt/robot/telemetry</topic>
            <topic>rt/diagnostics/*</topic>
          </topics>
        </publish>
        <subscribe>
          <topics>
            <topic>rt/robot/*</topic>
            <topic>rt/diagnostics/*</topic>
          </topics>
        </subscribe>
      </allow_rule>

      <default>DENY</default>
    </grant>
  </permissions>
</dds>
