# Lab-specific Suricata rules for ICS protocol abuse detection.
#
# These supplement the ET Open ruleset; they are tailored to the
# Robotics Security Platform's IP plan and traffic baseline.
#
# Rule sid range: 9000000-9000099 (lab-internal).

# ---------------------------------------------------------------------
# 9000001 - Modbus write to motor_arm_enable (coil 0) from non-HMI src
# ---------------------------------------------------------------------
alert tcp !$KNOWN_HMI any -> $MODBUS_SERVER 502 ( \
    msg:"LAB Modbus write to motor_arm_enable from non-HMI"; \
    flow:established,to_server; \
    app-layer-protocol:modbus; \
    modbus:function 5; \
    modbus:access write coils 0; \
    classtype:attempted-admin; \
    sid:9000001; rev:1;)

# ---------------------------------------------------------------------
# 9000002 - Modbus write to cycle_step (holding reg 0) with out-of-range value
# ---------------------------------------------------------------------
alert tcp any any -> $MODBUS_SERVER 502 ( \
    msg:"LAB Modbus write to cycle_step register"; \
    flow:established,to_server; \
    app-layer-protocol:modbus; \
    modbus:function 6; \
    modbus:access write holding 0; \
    classtype:attempted-admin; \
    sid:9000002; rev:1;)

# ---------------------------------------------------------------------
# 9000003 - High-rate Modbus from a single source (replay attack signature)
# ---------------------------------------------------------------------
alert tcp $EXTERNAL_NET any -> $MODBUS_SERVER 502 ( \
    msg:"LAB high-rate Modbus from external source"; \
    flow:established,to_server; \
    threshold:type both, track by_src, count 50, seconds 5; \
    app-layer-protocol:modbus; \
    classtype:attempted-dos; \
    sid:9000003; rev:1;)

# ---------------------------------------------------------------------
# 9000004 - Modbus connection from IT zone to OT (should never happen)
# ---------------------------------------------------------------------
alert tcp $IT_ZONE any -> $OT_ZONE 502 ( \
    msg:"LAB Modbus connection from IT zone to OT (Purdue zone violation)"; \
    flow:to_server; \
    app-layer-protocol:modbus; \
    classtype:policy-violation; \
    sid:9000004; rev:1;)

# ---------------------------------------------------------------------
# 9000005 - Modbus exception responses (PLC rejecting commands)
# ---------------------------------------------------------------------
alert tcp $MODBUS_SERVER 502 -> any any ( \
    msg:"LAB Modbus exception response from PLC"; \
    flow:established,from_server; \
    app-layer-protocol:modbus; \
    modbus:function >127; \
    classtype:bad-unknown; \
    sid:9000005; rev:1;)

# ---------------------------------------------------------------------
# 9000010 - DNP3 unsolicited response from non-OT source
# ---------------------------------------------------------------------
alert tcp $EXTERNAL_NET any -> $OT_ZONE 20000 ( \
    msg:"LAB DNP3 unsolicited from non-OT"; \
    flow:to_server; \
    app-layer-protocol:dnp3; \
    classtype:policy-violation; \
    sid:9000010; rev:1;)
