{
  "title": "Robotics Security Platform — SOC",
  "uid": "lab-soc",
  "description": "Unified Security Operations Center: OT/IT segmentation, AI anomaly detection, functional safety, vulnerability management, DevSecOps and incident response — all live.",
  "tags": ["lab", "robotics", "ot-security", "soc"],
  "timezone": "browser",
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "schemaVersion": 39,
  "version": 1,
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "row", "title": "Mission Status",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 10, "type": "stat", "title": "Safety State",
      "description": "Functional-safety supervisor state of the robot cell.",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage3_safety_state" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": {
          "0": { "text": "NORMAL", "color": "green", "index": 0 },
          "1": { "text": "DEGRADED", "color": "orange", "index": 1 },
          "2": { "text": "EMERGENCY", "color": "red", "index": 2 } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 2 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 11, "type": "stat", "title": "Attack Status",
      "description": "1 = a live attack is in progress against the OT cell.",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_attack_injection_active" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": {
          "0": { "text": "CLEAR", "color": "green", "index": 0 },
          "1": { "text": "UNDER ATTACK", "color": "red", "index": 1 } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 12, "type": "stat", "title": "Open Incidents",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage6_open_incidents" } ],
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 13, "type": "stat", "title": "Pending Approvals",
      "description": "Containment actions awaiting human (SOC analyst) approval.",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage6_pending_approvals" } ],
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 14, "type": "stat", "title": "Critical CVEs",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage4_vuln_count{severity=\"critical\"}" } ],
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 15, "type": "stat", "title": "CI/CD Gate",
      "description": "Stage 5 DevSecOps pipeline verdict (1 = PASS).",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage5_pipeline_last_verdict{verdict=\"PASS\"}" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": {
          "0": { "text": "FAIL", "color": "red", "index": 0 },
          "1": { "text": "PASS", "color": "green", "index": 1 } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 16, "type": "stat", "title": "SIS Integrity",
      "description": "Safety Instrumented System integrity (1 = verified).",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage3_sis_integrity" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": {
          "0": { "text": "TAMPERED", "color": "red", "index": 0 },
          "1": { "text": "VERIFIED", "color": "green", "index": 1 } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 17, "type": "gauge", "title": "IEC 62443 Compliance",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_iec62443_compliance_score" } ],
      "fieldConfig": { "defaults": {
        "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 60 }, { "color": "green", "value": 80 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 2, "type": "row", "title": "AI-Driven Anomaly Detection",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 20, "type": "timeseries", "title": "Network Anomaly Detectors  ·  IsolationForest / PCA-AE / TF-AE",
      "description": "Live per-window scores from the Modbus-network detection plane. PCA/TF are z-scores (alert ≳ 3σ).",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage2_latest_iforest_score", "legendFormat": "IsolationForest" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage2_latest_pca_z", "legendFormat": "PCA-AE z" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage2_latest_tf_z", "legendFormat": "TF-AE z" }
      ],
      "fieldConfig": { "defaults": {
        "unit": "short",
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 18, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true },
        "color": { "mode": "palette-classic" },
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 3 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 21, "type": "timeseries", "title": "Robot Behavior Anomaly  ·  LSTM z-score",
      "description": "Physical-plane detection: LSTM autoencoder + physics envelope on the live joint-state stream.",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_robot_lstm_z", "legendFormat": "Robot LSTM z" } ],
      "fieldConfig": { "defaults": {
        "unit": "short",
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 22, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true },
        "color": { "mode": "continuous-GrYlRd" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 22, "type": "stat", "title": "Detection Latency",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_detection_latency_seconds" } ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2,
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 10 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "center" }
    },
    {
      "id": 23, "type": "stat", "title": "Anomaly Alerts (total)",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage2_alerts_total" } ],
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
        "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "center" }
    },
    {
      "id": 24, "type": "timeseries", "title": "Suricata IDS  ·  Events vs Alerts (rate / 5m)",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "sum(rate(lab_suricata_events_total[5m]))", "legendFormat": "events/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "sum(rate(lab_suricata_alerts_total[5m]))", "legendFormat": "alerts/s" }
      ],
      "fieldConfig": { "defaults": {
        "unit": "cps",
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true },
        "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3, "type": "row", "title": "OT Network & Industrial Protocol",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 30, "type": "timeseries", "title": "Modbus/TCP Traffic Rate",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 19 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage1_modbus_traffic_rate", "legendFormat": "req/s" } ],
      "fieldConfig": { "defaults": {
        "unit": "reqps",
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "never", "spanNulls": true },
        "color": { "mode": "fixed", "fixedColor": "cyan" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 31, "type": "timeseries", "title": "Zeek Modbus Features Parsed (rate / 5m)",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 19 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "sum(rate(lab_zeek_modbus_features_total[5m]))", "legendFormat": "features/s" } ],
      "fieldConfig": { "defaults": {
        "unit": "cps",
        "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60, "gradientMode": "hue", "showPoints": "never", "spanNulls": true },
        "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 32, "type": "stat", "title": "Zeek Features (cumulative)",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 19 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "sum(lab_zeek_modbus_features_total)" } ],
      "fieldConfig": { "defaults": { "unit": "short",
        "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "center" }
    },
    {
      "id": 4, "type": "row", "title": "Vulnerability Management & DevSecOps",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 40, "type": "bargauge", "title": "CVE Findings by Severity",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 27 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage4_vuln_count", "legendFormat": "{{severity}}" } ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0,
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 41, "type": "stat", "title": "Total Findings",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 8, "y": 27 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "sum(lab_stage4_vuln_count)" } ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 42, "type": "stat", "title": "Firmware Patch Status",
      "description": "1 = firmware baseline matches the approved signed image.",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 12, "y": 27 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage4_firmware_patch_status" } ],
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": {
          "0": { "text": "DRIFT", "color": "red", "index": 0 },
          "1": { "text": "COMPLIANT", "color": "green", "index": 1 } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 43, "type": "stat", "title": "Config Baseline Drift",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 27 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "sum(lab_stage4_baseline_drift_count)" } ],
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 44, "type": "stat", "title": "Last Pipeline Age",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 27 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage5_pipeline_age_seconds" } ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "id": 5, "type": "row", "title": "Incident Response & Component Health",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }
    },
    {
      "id": 50, "type": "bargauge", "title": "IR Incidents by Playbook",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 35 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_stage6_incidents_by_playbook", "legendFormat": "{{playbook}}" } ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "color": { "mode": "continuous-BlPu" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 51, "type": "bargauge", "title": "Component Health  ·  1 = reachable",
      "datasource": { "type": "prometheus", "uid": "lab-prometheus" },
      "gridPos": { "h": 7, "w": 16, "x": 8, "y": 35 },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "lab-prometheus" }, "expr": "lab_component_up", "legendFormat": "{{component}}" } ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1,
        "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "index": 0 }, "1": { "text": "UP", "index": 1 } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
        "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "lcd", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    }
  ]
}
