{
  "title": "Incident View",
  "uid": "lab-ir-v2",
  "description": "Active incident status, AI evidence, detection latency, and alert timeline for IR operators.",
  "tags": [
    "lab",
    "incidents",
    "ir"
  ],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 38,
  "version": 2,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "\ud83d\udea8 Incident Response \u2014 Live Status",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Open Incidents",
      "description": "Active IR incidents. Each incident tracks a detected attack through NIST SP 800-61 phases.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage6_open_incidents",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending Approvals",
      "description": "Containment steps (Isolate, Slow, Stop) waiting for operator approval on the Incidents page.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage6_pending_approvals",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Safety State",
      "description": "0=NORMAL  1=DEGRADED  2=EMERGENCY. Non-zero during/after an IR-driven safe state assertion.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage3_safety_state",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Attack Injection Active",
      "description": "1 = a demo attack is running right now. Should trigger incident within detection latency window.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_attack_injection_active",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Detection Latency",
      "description": "Time from attack injection start to first AI alert. Measures end-to-end detection pipeline speed.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_detection_latency_seconds",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "IEC 62443 Compliance",
      "description": "Compliance score \u2014 drops during active incidents due to open incidents and pending approvals.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_iec62443_compliance_score",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "\ud83e\udd16 AI Evidence & Threat Analysis",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "IsolationForest Score",
      "description": "Current IF anomaly score. Evidence for the 'AI Anomaly Detected' playbook trigger.",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage2_latest_iforest_score",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 0.5,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.12
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "PCA Z-Score",
      "description": "Current PCA reconstruction error z-score. Corroborates IsolationForest findings.",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage2_latest_pca_z",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 7,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2.5
              },
              {
                "color": "red",
                "value": 3.5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Incidents by Playbook",
      "description": "Total incident count per playbook. Identifies which attack patterns recur most frequently.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage6_incidents_by_playbook{playbook!=\"none\"}",
          "legendFormat": "{{playbook}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "IF Score & PCA Z-Score During Incidents",
      "description": "Overlay of both model scores during incident timeframe. Sustained elevation = confirmed attack.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage2_latest_iforest_score",
          "legendFormat": "IForest Score",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_stage2_latest_pca_z / 7",
          "legendFormat": "PCA Z-Score (normalized /7)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "0.15 + 0 * lab_stage2_latest_iforest_score",
          "legendFormat": "IF Alert Threshold 0.15",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "transparent",
                "value": null
              },
              {
                "color": "semi-dark-orange",
                "value": 0.15
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "\ud83d\udcc8 Anomaly Rate & Alert Timeline",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Anomaly Alert Rate by Category",
      "description": "Per-category anomaly rate during this incident window. Attack categories will spike at injection start.",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "rate(lab_stage2_alerts_total{category!~\"none|unknown\"}[1m]) * 60",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Component Health During Incident",
      "description": "Key component reachability during the incident. Drops indicate the attack caused service disruption.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "lab-prometheus"
          },
          "expr": "lab_component_up{component=~\"stage3_openplc_production|stage3_openplc_safety|stage2_score_service|stage2_redis_bus\"}",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "transparent",
                "value": null
              },
              {
                "color": "semi-dark-red",
                "value": 0
              },
              {
                "color": "semi-dark-green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "current": {}
      }
    ]
  }
}