# Secrets — never commit
.env
*.env.local

# Model artifacts (large binary files)
vm-ai/models/*.pkl
vm-ai/models/*.h5
vm-ai/models/*.json

# Build artifacts
dashboard/dist/

# Node dependencies (regenerated by npm/Docker build)
node_modules/

# Python bytecode
__pycache__/
*.pyc

# Local AI-assistant tool config (not part of the project)
.claude/
.agents/

# Local-only planning/export artifacts — not part of the shipped project
phase1-idmz-architecture.excalidraw
phase1-idmz-architecture.png
skills-lock.json
